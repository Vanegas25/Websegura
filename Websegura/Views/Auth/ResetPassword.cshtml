@model Websegura.Models.ResetPasswordViewModel
@{
    ViewData["Title"] = "Restablecer Contraseña";
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Restablecer Contraseña - WebSegura</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <style>
        :root {
            --bg-gradient: radial-gradient(circle at 50% 50%, #1a162b, #08060f);
            --card-bg: rgba(25, 22, 43, 0.75);
            --primary-accent: #ff477e;
            --primary-hover: #e03265;
            --input-focus-glow: rgba(255, 71, 126, 0.2);
            --bg-input: rgba(13, 11, 26, 0.7);
        }

        body {
            background: var(--bg-gradient);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', sans-serif;
        }

        .login-card {
            background: var(--card-bg);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.075);
            border-radius: 20px;
            width: 100%;
            max-width: 420px;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.6);
        }

        /* Estilos personalizados para el Input Group con Floating Labels */
        .password-group {
            position: relative;
            display: flex;
            align-items: stretch;
            width: 100%;
            background-color: var(--bg-input);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 10px;
            transition: all 0.3s ease;
        }

            .password-group:focus-within {
                border-color: var(--primary-accent);
                box-shadow: 0 0 0 4px var(--input-focus-glow);
                background-color: rgba(13, 11, 26, 0.9);
            }

            .password-group .form-floating {
                flex: 1 1 auto;
                width: 1%;
            }

            .password-group .form-control {
                background: transparent !important;
                border: none !important;
                color: #fff !important;
                box-shadow: none !important;
            }

            .password-group .btn-eye {
                background: transparent;
                border: none;
                color: #a0aed0;
                padding: 0 15px;
                transition: color 0.2s;
            }

                .password-group .btn-eye:hover {
                    color: var(--primary-accent);
                }

        .form-floating > label {
            color: #a0aed0;
        }

        .form-floating > .form-control:focus ~ label,
        .form-floating > .form-control:not(:placeholder-shown) ~ label {
            color: var(--primary-accent);
        }

        /* Caja de Requerimientos de la Contraseña */
        .requirements-box {
            background: rgba(13, 11, 26, 0.5);
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: 10px;
            padding: 12px 15px;
        }

        .requirement {
            font-size: 0.8rem;
            color: #a0aed0;
            transition: color 0.3s ease, transform 0.2s ease;
            display: flex;
            align-items: center;
        }

            .requirement i {
                margin-right: 8px;
                font-size: 0.9rem;
            }

            .requirement.valid {
                color: #2ec4b6;
                font-weight: 500;
            }

                .requirement.valid i::before {
                    content: "\f272"; /* Icono de check-circle en Bootstrap Icons */
                }

        .btn-custom {
            background: linear-gradient(135deg, var(--primary-accent), #ff6b8b);
            border: none;
            color: white;
            font-weight: 600;
            border-radius: 10px;
            padding: 12px;
            transition: all 0.3s ease;
        }

            .btn-custom:hover {
                background: linear-gradient(135deg, var(--primary-hover), var(--primary-accent));
                transform: translateY(-2px);
                box-shadow: 0 8px 20px rgba(255, 71, 126, 0.4);
                color: white;
            }

            .btn-custom:disabled {
                background: #2a2542;
                color: #655f80;
                transform: none;
                box-shadow: none;
                cursor: not-allowed;
            }
    </style>
</head>
<body>
    <div class="container d-flex justify-content-center p-3">
        <div class="login-card p-4 p-sm-5">
            <div class="text-center mb-4">
                <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-3" style="width: 60px; height: 60px; background-color: rgba(255, 71, 126, 0.15);">
                    <i class="bi bi-shield-lock-fill fs-3" style="color: var(--primary-accent);"></i>
                </div>
                <h2 class="fw-bold text-white mb-1 fs-3">Nueva Contraseña</h2>
                <p class="text-white-50 small">Ingresa las credenciales para actualizar tu cuenta de forma segura.</p>
            </div>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger small p-2.5 mb-3" role="alert" style="background: rgba(220, 53, 69, 0.15); border-color: rgba(220, 53, 69, 0.3); color: #ea868f; border-radius: 10px;">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>@ViewBag.Error
                </div>
            }

            <form asp-action="ResetPassword" asp-controller="Auth" method="post" autocomplete="off" id="resetForm">
                <input type="hidden" asp-for="Token" />
                <input type="hidden" asp-for="Email" />

                <div class="password-group mb-3">
                    <div class="form-floating">
                        <input asp-for="Password" type="password" class="form-control" id="floatingPassword" placeholder="Nueva Contraseña" required />
                        <label for="floatingPassword"><i class="bi bi-lock me-2"></i>Nueva Contraseña</label>
                    </div>
                    <button type="button" class="btn-eye" id="togglePassword" tabIndex="-1">
                        <i class="bi bi-eye-slash" id="eyeIcon"></i>
                    </button>
                </div>

                <div class="requirements-box mb-3">
                    <div class="requirement mb-1.5" id="reqLength">
                        <i class="bi bi-circle"></i> Mínimo 8 caracteres
                    </div>
                    <div class="requirement mb-1.5" id="reqUpper">
                        <i class="bi bi-circle"></i> Al menos una mayúscula (A-Z)
                    </div>
                    <div class="requirement mb-1.5" id="reqLower">
                        <i class="bi bi-circle"></i> Al menos una minúscula (a-z)
                    </div>
                    <div class="requirement mb-1.5" id="reqNumber">
                        <i class="bi bi-circle"></i> Al menos un número (0-9)
                    </div>
                    <div class="requirement" id="reqSpecial">
                        <i class="bi bi-circle"></i> Carácter especial (@@, #, $, !, etc.)
                    </div>
                </div>

                <div class="password-group mb-4">
                    <div class="form-floating">
                        <input asp-for="ConfirmPassword" type="password" class="form-control" id="floatingConfirmPassword" placeholder="Confirmar Contraseña" required />
                        <label for="floatingConfirmPassword"><i class="bi bi-lock-check me-2"></i>Confirmar Contraseña</label>
                    </div>
                    <button type="button" class="btn-eye" id="toggleConfirmPassword" tabIndex="-1">
                        <i class="bi bi-eye-slash" id="confirmEyeIcon"></i>
                    </button>
                </div>

                <button type="submit" class="btn btn-custom w-100 shadow-sm" id="submitBtn" disabled>
                    Actualizar Contraseña <i class="bi bi-check-lg ms-1"></i>
                </button>
            </form>
        </div>
    </div>

    <script>
        const passwordInput = document.getElementById('floatingPassword');
        const confirmInput = document.getElementById('floatingConfirmPassword');
        const submitBtn = document.getElementById('submitBtn');

        // Alternadores de Visibilidad (Ojo)
        document.getElementById('togglePassword').addEventListener('click', function() {
            const isPassword = passwordInput.type === 'password';
            passwordInput.type = isPassword ? 'text' : 'password';
            document.getElementById('eyeIcon').className = isPassword ? 'bi bi-eye' : 'bi bi-eye-slash';
        });

        document.getElementById('toggleConfirmPassword').addEventListener('click', function() {
            const isPassword = confirmInput.type === 'password';
            confirmInput.type = isPassword ? 'text' : 'password';
            document.getElementById('confirmEyeIcon').className = isPassword ? 'bi bi-eye' : 'bi bi-eye-slash';
        });

        // Validaciones en Tiempo Real (Regex)
        passwordInput.addEventListener('input', validateForm);
        confirmInput.addEventListener('input', validateForm);

        function validateForm() {
            const value = passwordInput.value;
            const confirmValue = confirmInput.value;

            // Evaluaciones de patrones de seguridad
            const criteria = {
                length: value.length >= 8,
                upper: /[A-Z]/.test(value),
                lower: /[a-z]/.test(value),
                number: /[0-9]/.test(value),
                special: /[^A-Za-z0-9]/.test(value)
            };

            // Cambiar estados visuales de los requerimientos
            updateRequirementUI('reqLength', criteria.length);
            updateRequirementUI('reqUpper', criteria.upper);
            updateRequirementUI('reqLower', criteria.lower);
            updateRequirementUI('reqNumber', criteria.number);
            updateRequirementUI('reqSpecial', criteria.special);

            // Verificar si todo es correcto y si coinciden las contraseñas
            const allCriteriaMet = Object.values(criteria).every(Boolean);
            const passwordsMatch = value === confirmValue && value.length > 0;

            // Desbloquea el botón solo si pasa las validaciones de robustez y coincidencia
            submitBtn.disabled = !(allCriteriaMet && passwordsMatch);
        }

        function updateRequirementUI(elementId, isValid) {
            const el = document.getElementById(elementId);
            const icon = el.querySelector('i');

            if (isValid) {
                el.classList.add('valid');
                icon.className = 'bi bi-check-circle-fill';
            } else {
                el.classList.remove('valid');
                icon.className = 'bi bi-circle';
            }
        }
    </script>
</body>
</html>