@model Websegura.Models.OtpViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Verificación 2FA - WebSegura</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">

    <style>
        :root {
            --bg-gradient: radial-gradient(circle at 50% 50%, #1a162b, #08060f);
            --card-bg: rgba(25, 22, 43, 0.75);
            --primary-accent: #ff477e;
            --primary-hover: #e03265;
            --input-focus-glow: rgba(255, 71, 126, 0.2);
        }

        body {
            background: var(--bg-gradient);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', system-ui, sans-serif;
        }

        .card-2fa {
            background: var(--card-bg);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.075);
            border-radius: 20px;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.6);
            width: 100%;
            max-width: 400px;
        }

        .form-floating > .form-control {
            background-color: rgba(13, 11, 26, 0.7);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: #fff;
            border-radius: 10px;
            font-size: 1.5rem;
            font-weight: 600;
            letter-spacing: 8px;
            text-align: center;
        }

            .form-floating > .form-control:focus {
                background-color: rgba(13, 11, 26, 0.9);
                border-color: var(--primary-accent);
                box-shadow: 0 0 0 4px var(--input-focus-glow);
                color: #fff;
            }

        .form-floating > label {
            color: #a0aed0;
            width: 100%;
            text-align: center;
            letter-spacing: normal;
        }

        .form-floating > .form-control:focus ~ label,
        .form-floating > .form-control:not(:placeholder-shown) ~ label {
            color: var(--primary-accent);
            text-align: left;
            padding-left: 12px;
        }

        .btn-custom {
            background: linear-gradient(135deg, var(--primary-accent), #ff6b8b);
            border: none;
            color: white;
            font-weight: 600;
            border-radius: 10px;
            padding: 12px;
            transition: all 0.3s ease;
        }

            .btn-custom:hover {
                background: linear-gradient(135deg, var(--primary-hover), var(--primary-accent));
                transform: translateY(-2px);
                box-shadow: 0 8px 20px rgba(255, 71, 126, 0.4);
                color: white;
            }

            .btn-custom:active {
                transform: translateY(0);
            }

        .cancel-link {
            color: #a0aed0;
            text-decoration: none;
            transition: color 0.2s ease;
        }

            .cancel-link:hover {
                color: var(--primary-accent);
            }
    </style>
</head>
<body>

    <div class="container d-flex justify-content-center p-3">
        <div class="card-2fa p-4 p-sm-5">

            <div class="text-center mb-4">
                <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-3" style="width: 60px; height: 60px; background-color: rgba(255, 71, 126, 0.15);">
                    <i class="bi bi-shield-check-fill fs-3" style="color: var(--primary-accent);"></i>
                </div>
                <h2 class="fw-bold text-white mb-1" style="letter-spacing: -0.5px;">Verificación 2FA</h2>
                <p class="text-white-50 small">Introduce el código de seguridad para continuar</p>
            </div>

            @if (TempData["OtpUser"] != null)
            {
                <div class="text-center mb-4 p-3 rounded-3" style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05);">
                    <p class="text-white small mb-0">
                        <i class="bi bi-envelope-check text-info me-1"></i> Hemos enviado un código de acceso al correo vinculado a la cuenta de <strong class="text-info">@TempData["OtpUser"]</strong>.
                    </p>
                    <span class="text-muted d-block mt-2" style="font-size: 0.72rem;">
                        <i class="bi bi-clock-history me-1"></i> El código expirará en 2 minutos
                    </span>
                </div>
            }

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger d-flex align-items-center mb-4" role="alert" style="background: rgba(220, 53, 69, 0.15); border-color: rgba(220, 53, 69, 0.3); color: #ea868f; border-radius: 10px;">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    <div class="small">@ViewBag.Error</div>
                </div>
            }

            <form method="post" autocomplete="off">
                <div class="form-floating mb-4">
                    <input asp-for="Code" type="text" class="form-control" id="floatingOtp" placeholder="000000" maxlength="6" pattern="\d{6}" required autocomplete="one-time-code" inputmode="numeric" />
                    <label for="floatingOtp">Código de Verificación</label>
                </div>

                <button type="submit" class="btn btn-custom w-100 py-2.5 mb-3 shadow-sm">
                    Verificar Código <i class="bi bi-patch-check ms-1"></i>
                </button>
            </form>

            <div class="text-center mt-4">
                <a href="/Auth/Login" class="cancel-link small">
                    <i class="bi bi-arrow-left me-1"></i> Volver al Login
                </a>
            </div>

        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.getElementById('floatingOtp').addEventListener('input', function (e) {
            this.value = this.value.replace(/[^0-9]/g, '');
        });
    </script>
</body>
</html>