@model Websegura.Models.RegisterViewModel
@{
    ViewData["Title"] = "Registro";
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Registro - WebSegura</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">

    <style>
        :root {
            --bg-gradient: radial-gradient(circle at 50% 50%, #1a162b, #08060f);
            --card-bg: rgba(25, 22, 43, 0.75);
            --primary-accent: #ff477e;
            --primary-hover: #e03265;
            --input-focus-glow: rgba(255, 71, 126, 0.2);
        }

        body {
            background: var(--bg-gradient);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', system-ui, sans-serif;
        }

        .register-card {
            background: var(--card-bg);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.075);
            border-radius: 20px;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.6);
            width: 100%;
            max-width: 420px;
        }

        /* Contenedor relativo para posicionar el ojo */
        .password-container {
            position: relative;
        }

        /* Estilos para inputs flotantes oscuros */
        .form-floating > .form-control {
            background-color: rgba(13, 11, 26, 0.7);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: #fff;
            border-radius: 10px;
            padding-right: 45px; /* Espacio para que el texto no se monte en el ojo */
        }

            .form-floating > .form-control:focus {
                background-color: rgba(13, 11, 26, 0.9);
                border-color: var(--primary-accent);
                box-shadow: 0 0 0 4px var(--input-focus-glow);
                color: #fff;
            }

        .form-floating > label {
            color: #a0aed0;
        }

        .form-floating > .form-control:focus ~ label,
        .form-floating > .form-control:not(:placeholder-shown) ~ label {
            color: var(--primary-accent);
        }

        /* Botón del ojo estilizado */
        .toggle-password {
            position: absolute;
            right: 15px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            color: #a0aed0;
            cursor: pointer;
            z-index: 10;
            padding: 0;
            font-size: 1.1rem;
            transition: color 0.2s;
        }

            .toggle-password:hover {
                color: var(--primary-accent);
            }

        /* Estilos específicos para las barras de seguridad */
        .strength-meter {
            height: 6px;
            background-color: rgba(255, 255, 255, 0.1);
            border-radius: 3px;
            transition: all 0.3s ease;
        }

        /* Banner de retroalimentación de estado */
        .status-feedback {
            border-radius: 10px;
            font-size: 0.78rem;
            transition: all 0.3s ease;
            display: none;
        }

        /* Botón personalizado */
        .btn-custom {
            background: linear-gradient(135deg, var(--primary-accent), #ff6b8b);
            border: none;
            color: white;
            font-weight: 600;
            border-radius: 10px;
            padding: 12px;
            transition: all 0.3s ease;
        }

            .btn-custom:hover {
                background: linear-gradient(135deg, var(--primary-hover), var(--primary-accent));
                transform: translateY(-2px);
                box-shadow: 0 8px 20px rgba(255, 71, 126, 0.4);
                color: white;
            }

            .btn-custom:active {
                transform: translateY(0);
            }

        .login-link {
            color: #a0aed0;
            text-decoration: none;
            transition: color 0.2s ease;
        }

            .login-link:hover {
                color: var(--primary-accent);
            }
    </style>
</head>
<body>

    <div class="container d-flex justify-content-center p-3">
        <div class="register-card p-4 p-sm-5">

            <div class="text-center mb-4">
                <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-3" style="width: 60px; height: 60px; background-color: rgba(255, 71, 126, 0.15);">
                    <i class="bi bi-person-plus-fill fs-3" style="color: var(--primary-accent);"></i>
                </div>
                <h2 class="fw-bold text-white mb-1" style="letter-spacing: -0.5px;">Crear Cuenta</h2>
                <p class="text-white small">Regístrate para obtener acceso seguro al sistema</p>
            </div>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger d-flex align-items-center" role="alert" style="background: rgba(220, 53, 69, 0.15); border-color: rgba(220, 53, 69, 0.3); color: #ea868f; border-radius: 10px;">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    <div class="small">@ViewBag.Error</div>
                </div>
            }

            <form method="post" autocomplete="off">

                <div class="form-floating mb-3">
                    <input asp-for="Username" type="text" class="form-control" id="floatingUser" placeholder="Usuario" required autocomplete="username" />
                    <label for="floatingUser"><i class="bi bi-person me-2"></i>Usuario</label>
                </div>

                <div class="form-floating mb-3">
                    <input asp-for="Email" type="email" class="form-control" id="floatingEmail" placeholder="Correo electrónico" required />
                    <label for="floatingEmail"><i class="bi bi-envelope me-2"></i>Correo electrónico</label>
                </div>

                <div class="password-container mb-1">
                    <div class="form-floating">
                        <input asp-for="Password" type="password" class="form-control" id="floatingPassword" placeholder="Contraseña" required />
                        <label for="floatingPassword"><i class="bi bi-key me-2"></i>Contraseña</label>
                    </div>
                    <button type="button" class="toggle-password" onclick="toggleVisibility('floatingPassword', 'eyeIcon1')">
                        <i id="eyeIcon1" class="bi bi-eye"></i>
                    </button>
                </div>

                <div class="mb-3 px-1">
                    <div class="row g-1 mb-2">
                        <div class="col-4"><div id="bar1" class="strength-meter"></div></div>
                        <div class="col-4"><div id="bar2" class="strength-meter"></div></div>
                        <div class="col-4"><div id="bar3" class="strength-meter"></div></div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="text-secondary" style="font-size: 0.75rem;">Análisis de la clave:</span>
                        <strong id="strengthText" class="text-secondary small" style="font-size: 0.75rem;">Ingresa una contraseña</strong>
                    </div>

                    <div id="statusFeedback" class="status-feedback p-2 mb-2 text-center fw-medium"></div>

                    <ul id="passwordRequirements" class="list-unstyled m-0 p-0 text-start" style="font-size: 0.75rem; color: #a0aed0; line-height: 1.4;">
                        <li id="reqLargo"><i class="bi bi-x-circle-fill text-danger me-1"></i> Mínimo 8 caracteres</li>
                        <li id="reqMayus"><i class="bi bi-x-circle-fill text-danger me-1"></i> Mínimo 1 letra Mayúscula</li>
                        <li id="reqMinus"><i class="bi bi-x-circle-fill text-danger me-1"></i> Mínimo 1 letra Minúscula</li>
                        <li id="reqNumero"><i class="bi bi-x-circle-fill text-danger me-1"></i> Mínimo 1 Número</li>
                        <li id="reqSimbolo"><i class="bi bi-x-circle-fill text-danger me-1"></i> Mínimo 1 Carácter especial (ej: !@@#$)</li>
                    </ul>
                </div>

                <div class="password-container mb-4">
                    <div class="form-floating">
                        <input asp-for="ConfirmPassword" type="password" class="form-control" id="floatingConfirmPassword" placeholder="Confirmar contraseña" required />
                        <label for="floatingConfirmPassword"><i class="bi bi-key-fill me-2"></i>Confirmar contraseña</label>
                    </div>
                    <button type="button" class="toggle-password" onclick="toggleVisibility('floatingConfirmPassword', 'eyeIcon2')">
                        <i id="eyeIcon2" class="bi bi-eye"></i>
                    </button>
                </div>

                <button type="submit" class="btn btn-custom w-100 py-2.5 mb-3 shadow-sm">
                    Registrarse <i class="bi bi-person-check ms-1"></i>
                </button>
            </form>

            <div class="text-center mt-4">
                <a href="/Auth/Login" class="login-link small">
                    ¿Ya tienes cuenta? <span class="fw-semibold text-decoration-underline">Inicia sesión</span>
                </a>
            </div>

        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // Función reusable para alternar la visibilidad del texto
        function toggleVisibility(inputId, iconId) {
            const inputField = document.getElementById(inputId);
            const eyeIcon = document.getElementById(iconId);

            if (inputField.type === "password") {
                inputField.type = "text";
                eyeIcon.className = "bi bi-eye-slash"; // Cambia el icono a ojo tachado
            } else {
                inputField.type = "password";
                eyeIcon.className = "bi bi-eye"; // Regresa al ojo normal
            }
        }

        // Lógica del Medidor de Fuerza
        document.getElementById('floatingPassword').addEventListener('input', function () {
            const password = this.value;
            const bar1 = document.getElementById('bar1');
            const bar2 = document.getElementById('bar2');
            const bar3 = document.getElementById('bar3');
            const strengthText = document.getElementById('strengthText');
            const statusFeedback = document.getElementById('statusFeedback');

            const reqLargo = document.getElementById('reqLargo');
            const reqMayus = document.getElementById('reqMayus');
            const reqMinus = document.getElementById('reqMinus');
            const reqNumero = document.getElementById('reqNumero');
            const reqSimbolo = document.getElementById('reqSimbolo');

            const emptyColor = 'rgba(255, 255, 255, 0.1)';
            bar1.style.backgroundColor = emptyColor;
            bar2.style.backgroundColor = emptyColor;
            bar3.style.backgroundColor = emptyColor;

            if (password.length === 0) {
                strengthText.innerText = 'Ingresa una contraseña';
                strengthText.className = 'small text-secondary fw-medium';
                statusFeedback.style.display = 'none';
                resetearRequisitos();
                return;
            }

            statusFeedback.style.display = 'block';

            const cumpleLargo = password.length >= 8;
            const cumpleMayus = /[A-Z]/.test(password);
            const cumpleMinus = /[a-z]/.test(password);
            const cumpleNumero = /[0-9]/.test(password);
            const cumpleSimbolo = /[^A-Za-z0-9]/.test(password);

            actualizarItem(reqLargo, cumpleLargo, "Mínimo 8 caracteres");
            actualizarItem(reqMayus, cumpleMayus, "Mínimo 1 letra Mayúscula");
            actualizarItem(reqMinus, cumpleMinus, "Mínimo 1 letra Minúscula");
            actualizarItem(reqNumero, cumpleNumero, "Mínimo 1 Número");
            actualizarItem(reqSimbolo, cumpleSimbolo, "Mínimo 1 Carácter especial (ej: !@@#$)");

            let reglasCumplidas = 0;
            if (cumpleLargo) reglasCumplidas++;
            if (cumpleMayus) reglasCumplidas++;
            if (cumpleMinus) reglasCumplidas++;
            if (cumpleNumero) reglasCumplidas++;
            if (cumpleSimbolo) reglasCumplidas++;

            if (reglasCumplidas === 5) {
                bar1.style.backgroundColor = '#2ed573';
                bar2.style.backgroundColor = '#2ed573';
                bar3.style.backgroundColor = '#2ed573';
                strengthText.innerText = 'Fuerza: Alta 💪';
                strengthText.className = 'small text-success fw-bold';

                statusFeedback.style.backgroundColor = 'rgba(46, 213, 115, 0.15)';
                statusFeedback.style.color = '#2ed573';
                statusFeedback.innerHTML = '<i class="bi bi-shield-check me-1"></i> ¡Perfecto! Tu contraseña es muy segura.';
            }
            else if (reglasCumplidas >= 3 && cumpleLargo) {
                bar1.style.backgroundColor = '#ffa502';
                bar2.style.backgroundColor = '#ffa502';
                strengthText.innerText = 'Fuerza: Media ⚡';
                strengthText.className = 'small text-warning fw-bold';

                statusFeedback.style.backgroundColor = 'rgba(255, 165, 2, 0.15)';
                statusFeedback.style.color = '#ffa502';
                statusFeedback.innerHTML = '<i class="bi bi-shield-exclamation me-1"></i> Intermedia. Agrega los caracteres que faltan abajo para el nivel Máximo.';
            }
            else {
                bar1.style.backgroundColor = '#ff4757';
                strengthText.innerText = 'Fuerza: Baja ⚠️';
                strengthText.className = 'small text-danger fw-bold';

                statusFeedback.style.backgroundColor = 'rgba(255, 71, 87, 0.15)';
                statusFeedback.style.color = '#ff4757';

                if (!cumpleLargo) {
                    statusFeedback.innerHTML = '<i class="bi bi-info-circle me-1"></i> Demasiado corta. Escribe al menos 8 caracteres.';
                } else {
                    statusFeedback.innerHTML = '<i class="bi bi-info-circle me-1"></i> Muy simple. Combina letras, números y símbolos.';
                }
            }
        });

        function actualizarItem(elemento, cumple, texto) {
            if (cumple) {
                elemento.innerHTML = `<i class="bi bi-check-circle-fill text-success me-1"></i> <span class="text-decoration-line-through text-secondary">${texto}</span>`;
            } else {
                elemento.innerHTML = `<i class="bi bi-x-circle-fill text-danger me-1"></i> <span>${texto}</span>`;
            }
        }

        function resetearRequisitos() {
            actualizarItem(document.getElementById('reqLargo'), false, "Mínimo 8 caracteres");
            actualizarItem(document.getElementById('reqMayus'), false, "Mínimo 1 letra Mayúscula");
            actualizarItem(document.getElementById('reqMinus'), false, "Mínimo 1 letra Minúscula");
            actualizarItem(document.getElementById('reqNumero'), false, "Mínimo 1 Número");
            actualizarItem(document.getElementById('reqSimbolo'), false, "Mínimo 1 Carácter especial (ej: !@@#$)");
        }
    </script>
</body>
</html>