@model Websegura.Models.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Recuperar Contraseña";
    Layout = null; 
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Recuperar Contraseña - WebSegura</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <style>
        :root {
            --bg-gradient: radial-gradient(circle at 50% 50%, #1a162b, #08060f);
            --card-bg: rgba(25, 22, 43, 0.75);
            --primary-accent: #ff477e;
            --primary-hover: #e03265;
            --input-focus-glow: rgba(255, 71, 126, 0.2);
        }

        body {
            background: var(--bg-gradient);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', sans-serif;
        }

        .login-card {
            background: var(--card-bg);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.075);
            border-radius: 20px;
            width: 100%;
            max-width: 400px;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.6);
        }

        .form-floating > .form-control {
            background-color: rgba(13, 11, 26, 0.7);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: #fff;
            border-radius: 10px;
        }

            .form-floating > .form-control:focus {
                background-color: rgba(13, 11, 26, 0.9);
                border-color: var(--primary-accent);
                box-shadow: 0 0 0 4px var(--input-focus-glow);
                color: #fff;
            }

        .form-floating > label {
            color: #a0aed0;
        }

        .form-floating > .form-control:focus ~ label,
        .form-floating > .form-control:not(:placeholder-shown) ~ label {
            color: var(--primary-accent);
        }

        .btn-custom {
            background: linear-gradient(135deg, var(--primary-accent), #ff6b8b);
            border: none;
            color: white;
            font-weight: 600;
            border-radius: 10px;
            padding: 12px;
            transition: all 0.3s ease;
        }

            .btn-custom:hover {
                background: linear-gradient(135deg, var(--primary-hover), var(--primary-accent));
                transform: translateY(-2px);
                box-shadow: 0 8px 20px rgba(255, 71, 126, 0.4);
                color: white;
            }
    </style>
</head>
<body>
    <div class="container d-flex justify-content-center p-3">
        <div class="login-card p-4 p-sm-5">
            <div class="text-center mb-4">
                <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-3" style="width: 60px; height: 60px; background-color: rgba(71, 209, 255, 0.15);">
                    <i class="bi bi-envelope-at-fill fs-3" style="color: #47d1ff;"></i>
                </div>
                <h2 class="fw-bold text-white mb-1 fs-3">¿Olvidaste tu contraseña?</h2>
                <p class="text-white-50 small">Introduce tu correo para enviarte un enlace de recuperación.</p>
            </div>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger small p-2.5" role="alert" style="background: rgba(220, 53, 69, 0.15); border-color: rgba(220, 53, 69, 0.3); color: #ea868f; border-radius: 10px;">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>@ViewBag.Error
                </div>
            }
            @if (ViewBag.Success != null)
            {
                <div class="alert alert-success small p-2.5" role="alert" style="background: rgba(40, 167, 69, 0.15); border-color: rgba(40, 167, 69, 0.3); color: #71dd8a; border-radius: 10px;">
                    <i class="bi bi-check-circle-fill me-2"></i>@ViewBag.Success
                </div>
            }

            <form asp-action="ForgotPassword" asp-controller="Auth" method="post" autocomplete="off">
                <div class="form-floating mb-4">
                    <input asp-for="Email" type="email" class="form-control" id="floatingEmail" placeholder="correo@ejemplo.com" required />
                    <label for="floatingEmail"><i class="bi bi-envelope me-2"></i>Correo Electrónico</label>
                    <span asp-validation-for="Email" class="text-danger small d-block mt-1"></span>
                </div>

                <button type="submit" class="btn btn-custom w-100 shadow-sm">
                    Enviar Enlace <i class="bi bi-paper-plane ms-1"></i>
                </button>
            </form>

            <div class="text-center mt-4">
                <a href="/Auth/Login" class="text-decoration-none small" style="color: #a0aed0; transition: color 0.2s;" onmouseover="this.style.color='#ff477e'" onmouseout="this.style.color='#a0aed0'">
                    <i class="bi bi-arrow-left me-1"></i> Volver al Login
                </a>
            </div>
        </div>
    </div>
</body>
</html>